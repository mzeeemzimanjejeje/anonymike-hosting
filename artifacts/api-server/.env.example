# ─── Database ─────────────────────────────────────────────────────────────────
# Primary app database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: separate Neon DB for app data (sessions stay in DATABASE_URL)
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ─── Pterodactyl Panel ────────────────────────────────────────────────────────
# Panel URL (https:// is auto-added if missing)
PTERODACTYL_URL=https://your-panel.example.com

# Application API key (ptla_...) — server CRUD (create/delete/list)
PTERODACTYL_API_KEY=ptla_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Client API key (ptlc_...) — power signals, files, resource monitoring
PTERODACTYL_CLIENT_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated email addresses that have admin access
ADMIN_EMAILS=admin@example.com,admin2@example.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://your-domain.com/api/auth/github/callback

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Resend API key for transactional emails
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Payments (optional) ──────────────────────────────────────────────────────
# Payflow / M-Pesa integration
# PAYFLOW_API_KEY=
# PAYFLOW_SECRET=
# PAYFLOW_ACCOUNT_ID=
